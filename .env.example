# Private alpha foundations
APP_ENVIRONMENT=alpha
DATABASE_URL=postgresql+psycopg://sysadmin:sysadmin@localhost:5432/sysadmin
REDIS_URL=redis://localhost:6379/0
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# URL-safe base64 that decodes to exactly 32 random bytes.
ENCRYPTION_KEY=

# Safe defaults. Set these explicitly before touching real hosts.
COLLECTOR_MODE=demo
EXECUTION_MODE=simulate

# Provider routing order. Model names are intentionally operator-configured.
AI_PROVIDER_ORDER=openai,anthropic,ollama
AI_ORCHESTRATOR_PROVIDER=auto
AI_SPECIALIST_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_STRONG_MODEL=
OPENAI_ECONOMY_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_STRONG_MODEL=
ANTHROPIC_ECONOMY_MODEL=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_STRONG_MODEL=
OLLAMA_ECONOMY_MODEL=
